// This is your Prisma schema file.
// Learn more about it: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// USERS & AUTHENTICATION
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(CUSTOMER)
  tier      UserTier @default(STANDARD) // VIP flag for AI escalation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  trips            Trip[]
  supportChats     SupportChat[]
  travelerProfiles Traveler[]     // Saved passenger profiles for repeat bookings

  @@map("users")
}

enum UserRole {
  CUSTOMER
  SUPPORT_AGENT
  OPERATIONS
  ADMIN
}

enum UserTier {
  STANDARD
  VIP
  CORPORATE
}

// ─────────────────────────────────────────────
// TRAVELERS (passengers / guests on a trip)
// DELIBERATELY decoupled from User:
//   - The User is the person who PAYS
//   - Travelers are the people who actually TRAVEL
//   - A corporate admin (User) can book for 10 employees (Travelers)
//     who have no user account on the platform
// ─────────────────────────────────────────────

model Traveler {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  firstName String
  lastName  String
  email     String?
  phone     String?

  // Encrypted at rest — passports, DOB, KTN, visa numbers, ages
  documents Json     @default("{}")

  // A Traveler can be assigned across multiple TripItems
  // (same person on both the flight TripItem AND the hotel TripItem)
  tripItems TripItem[]

  @@index([userId])
  @@map("travelers")
}


// ─────────────────────────────────────────────
// TRIPS (the unified booking cart)
// ─────────────────────────────────────────────

model Trip {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  status     TripStatus @default(DRAFT)
  totalPrice Decimal    @db.Decimal(12, 2)
  currency   String     @default("NGN")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  // Relations
  items   TripItem[]
  payment Payment?

  @@index([userId])
  @@map("trips")
}

enum TripStatus {
  DRAFT           // Cart building phase
  PAID            // Payment captured by Paystack
  FULFILLING      // Workers are actively booking with providers
  CONFIRMED       // All items successfully booked
  PARTIAL_FAIL    // Some items failed — needs attention / partial refund
  CANCELLED       // User or system cancelled
  REFUNDED        // Full refund processed
}

// ─────────────────────────────────────────────
// TRIP ITEMS (polymorphic — flight / hotel / tour / car)
// The JSONB metadata field holds provider-specific data
// (PNR for flights, room type for hotels, guide ID for tours)
// ─────────────────────────────────────────────

model TripItem {
  id                String            @id @default(cuid())
  tripId            String
  trip              Trip              @relation(fields: [tripId], references: [id])
  type              TripItemType
  fulfillmentStatus FulfillmentStatus @default(PENDING)
  providerName      String            // e.g., "247_travels", "booking_com", "local_tour"
  price             Decimal           @db.Decimal(12, 2)
  currency          String            @default("NGN")

  // Provider-specific data: PNR, room codes, confirmation numbers, etc.
  metadata Json @default("{}")

  travelers Traveler[]

  @@index([tripId])
  @@map("trip_items")
}

enum TripItemType {
  FLIGHT
  HOTEL
  TOUR
  CAR
}

enum FulfillmentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id                  String        @id @default(cuid())
  tripId              String        @unique
  trip                Trip          @relation(fields: [tripId], references: [id])
  paystackReference   String        @unique
  amount              Decimal       @db.Decimal(12, 2)
  currency            String        @default("NGN")
  status              PaymentStatus @default(PENDING)
  paidAt              DateTime?
  createdAt           DateTime      @default(now())

  refunds Refund[]

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ─────────────────────────────────────────────
// REFUNDS
// ─────────────────────────────────────────────

model Refund {
  id        String       @id @default(cuid())
  paymentId String
  payment   Payment      @relation(fields: [paymentId], references: [id])
  amount    Decimal      @db.Decimal(12, 2)
  reason    RefundReason
  status    RefundStatus @default(PENDING)
  createdAt DateTime     @default(now())

  @@map("refunds")
}

enum RefundReason {
  TICKETING_FAILED
  HOTEL_UNAVAILABLE
  USER_CANCELLED
  PARTIAL_FULFILLMENT
}

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
}

// ─────────────────────────────────────────────
// MARKUP RULES (ops-managed, never hardcoded)
// Editable via the Admin Dashboard without a code deploy.
// The engine checks most-specific rule first (route > vertical > global).
// ─────────────────────────────────────────────

model MarkupRule {
  id          String          @id @default(cuid())
  name        String          // Human-readable label e.g. "Lagos–London Economy"
  vertical    TripItemType?   // null = applies to ALL verticals
  origin      String?         // IATA code — null = any origin
  destination String?         // IATA code — null = any destination
  cabinClass  String?         // "ECONOMY", "BUSINESS" etc. — null = any class
  userTier    UserTier?       // null = applies to all tiers (VIP may get lower markup)

  // Markup value — exactly ONE of these must be set
  flatAmount  Decimal?        @db.Decimal(12, 2) // Fixed amount in currency (e.g. ₦50,000)
  percentage  Decimal?        @db.Decimal(5, 4)  // e.g. 0.0500 = 5%

  currency    String          @default("NGN")
  isActive    Boolean         @default(true)
  priority    Int             @default(0)        // Higher = evaluated first (more specific)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   String?         // Admin user ID who created the rule

  @@index([vertical, isActive])
  @@index([origin, destination, isActive])
  @@map("markup_rules")
}

// ─────────────────────────────────────────────
// AI SUPPORT CHAT
// ─────────────────────────────────────────────

model SupportChat {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id])
  role      SupportChatRole
  message   String          @db.Text
  status    ChatStatus      @default(ACTIVE)
  createdAt DateTime        @default(now())

  @@index([userId])
  @@map("support_chats")
}

enum SupportChatRole {
  USER
  ASSISTANT
  HUMAN_AGENT
}

enum ChatStatus {
  ACTIVE
  NEEDS_HUMAN       // AI escalated — waiting for human agent
  NEEDS_HUMAN_URGENT // VIP or emergency — immediate human takeover
  RESOLVED
}
