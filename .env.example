# ─────────────────────────────────────────────────────────
# MASTER TRIP — Environment Variables Template
# Copy this to .env.local (apps/web) and .env (apps/workers)
# NEVER commit actual secrets to git
# ─────────────────────────────────────────────────────────

# ── DATABASE (Supabase) ──────────────────────────────────
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ── PAYMENTS ─────────────────────────────────────────────
PAYSTACK_SECRET_KEY="sk_live_xxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_live_xxxxxxxxxxxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK_xxxxxxxxxxxx"

# ── FLIGHT PROVIDER (247 Travels) ────────────────────────
TRAVELS_247_API_KEY="xxxxxxxxxxxx"
TRAVELS_247_BASE_URL="https://api.247travels.com/v1"

# ── HOTEL PROVIDER (Booking.com) ─────────────────────────
BOOKING_COM_API_KEY="xxxxxxxxxxxx"
BOOKING_COM_AFFILIATE_ID="xxxxxxxxxxxx"

# ── CACHE & QUEUES (Upstash) ─────────────────────────────
UPSTASH_REDIS_REST_URL="https://xxxxxxxxxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxx"
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN="xxxxxxxxxxxx"
QSTASH_CURRENT_SIGNING_KEY="sig_xxxxxxxxxxxx"
QSTASH_NEXT_SIGNING_KEY="sig_xxxxxxxxxxxx"

# ── AI (OpenRouter) ──────────────────────────────────────
OPENROUTER_API_KEY="sk-or-xxxxxxxxxxxx"
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"

# ── WORKERS URLS (QStash webhook targets) ────────────────
WORKER_FULFILLMENT_URL="https://master-trip-workers.fly.dev/fulfillment"
WORKER_SUPPORT_URL="https://master-trip-workers.fly.dev/support"

# ── AUTH (WorkOS) ────────────────────────────────────────
WORKOS_API_KEY="sk_xxxxxxxxxxxx"
WORKOS_CLIENT_ID="client_xxxxxxxxxxxx"

# ── NOTIFICATIONS ─────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"

# ── OBSERVABILITY ─────────────────────────────────────────
SENTRY_DSN="https://xxxxxxxxxxxx@o0.ingest.sentry.io/0"
